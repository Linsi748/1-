                "г. Москва, ул. Ленина, д. 15, кв. 42",
                "ponos",
                1234567890123456L

        );
        patient[1] = new Patient(
                "Петрова", "Мария", "Сергеевна",
                "г. Санкт-Петербург, пр. Невский, д. 25",
                "zolotukha",
                2345678901234567L

        );
        patient[2] = new Patient(
