import java.util.Scanner;
class Patient {
    String familia;
    String name;
    String ochestvo;
    String adres;
    String diagnoz;
    long nomercart;

    Patient(String familia, String name, String ochestvo, String adres, String diagnoz, long nomercart) {
        this.familia = familia;
        this.name = name;
        this.ochestvo = ochestvo;
        this.adres = adres;
        this.diagnoz = diagnoz;
        this.nomercart = nomercart;

    }
    void printInfo() {
        System.out.println(familia + " " + name + " " + ochestvo + "\nАдрес: " + adres + "\nТелефон: " + diagnoz + "\nКарта: " + nomercart );
    }
}
public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        Patient[] patient = new Patient[5];
        patient[0] = new Patient(
